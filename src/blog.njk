---
layout: layouts/base.njk
title: Blog
permalink: /blog/
---
<section class="page-hero">
  <h1>Blog &amp; News</h1>
  <p>Updates, behind-the-scenes writing and news from the world of the Chronicles.</p>
</section>
<section class="section">
  <div class="wrap">
    {% if collections.blog | length %}
    <div class="grid cards2">
      {% for post in collections.blog %}
      <a class="blog-card" href="{{ post.url }}">
        {% if post.data.image %}
        <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
        {% endif %}
        <div class="meta">{{ post.date | readableDate }}</div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.summary | truncate(160) }}</p>
        <span class="button" style="display:inline-block;">Read More &rarr;</span>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p style="text-align:center;color:var(--muted);font-size:20px;">No posts yet &mdash; check back soon.</p>
    {% endif %}
  </div>
</section>
