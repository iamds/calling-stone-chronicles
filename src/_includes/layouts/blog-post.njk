---
layout: layouts/base.njk
---
<section class="blog-post-header">
  {% if image %}
  <img src="{{ image }}" alt="{{ title }}" style="width:100%;max-height:420px;object-fit:cover;border-radius:18px;margin-bottom:32px;">
  {% endif %}
  <div class="eyebrow">{{ date | readableDate }}</div>
  <h1 style="font-size:clamp(36px,6vw,72px);margin:16px 0;">{{ title }}</h1>
  {% if summary %}
  <p style="color:var(--muted);font-size:20px;max-width:700px;margin:0 auto;">{{ summary }}</p>
  {% endif %}
</section>
<article class="blog-post-content">
  {{ content | safe }}
</article>
<div style="text-align:center;padding:40px 24px;">
  <a class="button" href="/blog/">&larr; All Posts</a>
</div>
