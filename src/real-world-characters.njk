---
layout: layouts/base.njk
title: Real World Characters
permalink: /real-world-characters/
---
<section class="page-hero">
  <h1>Real World Characters</h1>
  <p>Profiles of the people and personalities from the mortal world who shape the story.</p>
</section>
<section class="section">
  <div class="wrap grid cards3">
    {% for character in collections.real_world_characters %}
    <article class="card">
      {% if character.data.portrait %}
      <img src="{{ character.data.portrait }}" alt="{{ character.data.title }}">
      {% else %}
      <div class="placeholder">Portrait</div>
      {% endif %}
      <div class="card-body">
        <h3>{{ character.data.title }}</h3>
        <p>{{ character.data.description }}</p>
        {% if character.data.body %}
        <div style="color:var(--muted);">{{ character.data.body | markdown | safe }}</div>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
</section>
